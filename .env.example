# OpenAI API設定
OPENAI_API_KEY=your_openai_api_key_here

# データベース設定
DATABASE_URL=sqlite:///shadowing.db

# アプリケーション設定
DEBUG=true
HOST=localhost
PORT=8000

# CORS（フロントエンドのオリジン。複数はカンマ区切り）
# 開発時は未設定で http://localhost:3000, http://127.0.0.1:3000 を許可
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000